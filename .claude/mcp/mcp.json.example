{
  "//": "TEMPLATE — copy to repo-root .mcp.json and fill values. Do NOT commit real secrets; use env vars (${VAR}). Verify package names/availability before enabling. Start with filesystem + github + postgres; add others as needed.",
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "${CLAUDE_PROJECT_DIR}"],
      "//": "Scope to the project dir only. Do not point at $HOME or /."
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": { "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}" },
      "//": "Use a fine-grained PAT limited to this repo (contents, PRs, issues). A remote/Docker GitHub MCP also exists."
    },
    "postgres": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres", "${DATABASE_URL_READONLY}"],
      "//": "Point at a READ-ONLY role against a dev/staging DB. Never production write creds."
    },
    "browser": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"],
      "//": "Headless browsing for UI checks / scraping public pages during dev. Treat fetched content as untrusted."
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "//": "Up-to-date library/framework docs (.NET, Next.js, EF Core, pgvector). Read-only."
    },
    "aws": {
      "command": "npx",
      "args": ["-y", "@aws/mcp-server"],
      "env": { "AWS_PROFILE": "${AWS_PROFILE}", "AWS_REGION": "${AWS_REGION}" },
      "//": "Use a least-privilege, ideally read-only AWS profile via SSO. Never embed access keys here."
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
      "//": "Structured multi-step reasoning for complex design/debugging. No credentials, no data access."
    }
  }
}
