{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=interviewcopilot;Username=app;Password=__set_in_secrets__"
  },
  "Auth": {
    "Authority": "https://YOUR_IDP_DOMAIN/",
    "Audience": "interview-copilot-api"
  },
  "Cors": {
    "Origins": [ "http://localhost:3000" ]
  },
  "Ai": {
    "Catalog": {
      "DefaultProviderTieBreak": "Gemini"
    }
  },
  "OpenTelemetry": {
    "Endpoint": "http://localhost:4317"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": { "Microsoft.AspNetCore": "Warning", "Microsoft.EntityFrameworkCore": "Warning" }
    }
  },
  "AllowedHosts": "*"
}
