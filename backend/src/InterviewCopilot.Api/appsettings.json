{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=interviewcopilot;Username=app;Password=__set_in_secrets__"
  },
  "Auth": {
    "Issuer": "https://api.interviewcopilot.ai",
    "Audience": "interview-copilot",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 30,
    "SigningKeyId": "ic-auth-1",
    "SigningKeyPem": "__set_via_secrets_manager__",
    "IpHashSalt": "__set_via_secrets_manager__",
    "WebOrigin": "http://localhost:3000",
    "RefreshCookieName": "__Host-ic_refresh",
    "Google": {
      "ClientId": "__set_via_secrets_manager__",
      "ClientSecret": "__set_via_secrets_manager__",
      "RedirectUri": "https://api.interviewcopilot.ai/api/v1/auth/google/callback"
    }
  },
  "Cors": {
    "Origins": [ "http://localhost:3000" ]
  },
  "Ai": {
    "Catalog": {
      "DefaultProviderTieBreak": "Gemini"
    }
  },
  "OpenTelemetry": {
    "Endpoint": "http://localhost:4317"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": { "Microsoft.AspNetCore": "Warning", "Microsoft.EntityFrameworkCore": "Warning" }
    }
  },
  "AllowedHosts": "*"
}
